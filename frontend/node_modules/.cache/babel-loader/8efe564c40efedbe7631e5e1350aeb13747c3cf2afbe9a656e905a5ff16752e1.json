{"ast":null,"code":"import axios from 'axios';\nexport default {\n  data() {\n    return {\n      taskData: {\n        title: '',\n        description: '',\n        deadline: '',\n        status: 'En cours'\n      },\n      taskId: this.$route.params.taskId,\n      loading: false,\n      // Variable pour gérer l'affichage de l'animation de chargement\n      successMessage: '' // Message de succès\n    };\n  },\n\n  methods: {\n    async updateTask() {\n      try {\n        this.loading = true; // Activez l'animation de chargement pendant la soumission\n        const token = localStorage.getItem('token');\n        const headers = {\n          Authorization: `Bearer ${token}`\n        };\n        await axios.put(`/api/tasks/updatetask/${this.taskId}`, this.taskData, {\n          headers\n        });\n        // Émettez un message de succès\n        this.successMessage = 'Tâche mise à jour avec succès.';\n      } catch (error) {\n        console.log(error);\n      } finally {\n        this.loading = false; // Désactivez l'animation de chargement après la soumission\n      }\n    },\n\n    async fetchTaskData() {\n      try {\n        const token = localStorage.getItem('token');\n        const headers = {\n          Authorization: `Bearer ${token}`\n        };\n        const response = await axios.get(`/api/tasks/${this.taskId}`, {\n          headers\n        });\n        // Formatez la date au format \"yyyy-MM-dd\"\n        const taskData = response.data;\n        taskData.deadline = new Date(taskData.deadline).toISOString().split('T')[0];\n        this.taskData = response.data;\n      } catch (error) {\n        console.log(error.message);\n      }\n    }\n  },\n  watch: {\n    taskId: 'fetchTaskData'\n  },\n  created() {\n    this.fetchTaskData();\n  }\n};","map":{"version":3,"names":["axios","data","taskData","title","description","deadline","status","taskId","$route","params","loading","successMessage","methods","updateTask","token","localStorage","getItem","headers","Authorization","put","error","console","log","fetchTaskData","response","get","Date","toISOString","split","message","watch","created"],"sources":["C:\\Users\\melek\\Downloads\\projjett\\TaskManager-FullStackWebApp-GestionnairedeTaches-ApplicationFullStack\\frontend\\src\\views\\TaskUpdateForm.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <h3>Modifier la tâche</h3>\r\n    <form @submit.prevent=\"updateTask\">\r\n      <div class=\"form-group\">\r\n        <label for=\"title\">Titre :</label>\r\n        <input type=\"text\" id=\"title\" v-model=\"taskData.title\" class=\"form-control\" required>\r\n      </div>\r\n      <div class=\"form-group\">\r\n        <label for=\"description\">Description :</label>\r\n        <textarea id=\"description\" v-model=\"taskData.description\" class=\"form-control\" required></textarea>\r\n      </div>\r\n      <div class=\"form-group\">\r\n        <label for=\"deadline\">Date limite :</label>\r\n        <input type=\"date\" id=\"deadline\" v-model=\"taskData.deadline\" class=\"form-control\" required>\r\n      </div>\r\n      <div class=\"form-group\">\r\n        <label for=\"status\">Statut :</label>\r\n        <select id=\"status\" v-model=\"taskData.status\" class=\"form-control\" required>\r\n          <option  selected :value=\"taskData.status\">{{ taskData.status }}</option>\r\n          <option value=\"En cours\">En cours</option>\r\n          <option value=\"Terminée\">Terminée</option>\r\n          <option value=\"Reportée\">Reportée</option>\r\n        </select>\r\n      </div>\r\n      <div v-if=\"loading\">\r\n        <div class=\"loading-animation\">Chargement en cours...</div>\r\n      </div>\r\n      <div v-else>\r\n        <button type=\"submit\" class=\"btn btn-primary\">Mettre à jour</button>\r\n      </div>\r\n      <div v-if=\"successMessage\" class=\"text-success\">{{ successMessage }}</div>\r\n    </form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios';\r\n\r\nexport default \r\n{\r\n  data() \r\n  {\r\n    return {\r\n      taskData: \r\n      {\r\n        title: '',\r\n        description: '',\r\n        deadline: '',\r\n        status: 'En cours',\r\n      },\r\n      taskId: this.$route.params.taskId,\r\n      loading: false, // Variable pour gérer l'affichage de l'animation de chargement\r\n      successMessage: '', // Message de succès\r\n    };\r\n  },\r\n\r\n  methods: \r\n  {\r\n    async updateTask() \r\n    {\r\n      try {\r\n        this.loading = true; // Activez l'animation de chargement pendant la soumission\r\n        const token = localStorage.getItem('token');\r\n        const headers = { Authorization: `Bearer ${token}` };\r\n        await axios.put(`/api/tasks/updatetask/${this.taskId}`, this.taskData, { headers });\r\n        // Émettez un message de succès\r\n        this.successMessage = 'Tâche mise à jour avec succès.';\r\n      } \r\n      \r\n      catch (error) \r\n      {\r\n        console.log(error);\r\n      } \r\n\r\n      finally \r\n      {\r\n        this.loading = false; // Désactivez l'animation de chargement après la soumission\r\n      }\r\n    },\r\n\r\n    async fetchTaskData() \r\n    {\r\n      try \r\n      {\r\n        const token = localStorage.getItem('token');\r\n        const headers = { Authorization: `Bearer ${token}` };\r\n        const response = await axios.get(`/api/tasks/${this.taskId}`, { headers });\r\n        // Formatez la date au format \"yyyy-MM-dd\"\r\n        const taskData = response.data;\r\n        taskData.deadline = new Date(taskData.deadline).toISOString().split('T')[0];\r\n        this.taskData = response.data;\r\n      } \r\n\r\n      catch (error) \r\n      {\r\n        console.log(error.message);\r\n      }\r\n    },\r\n  },\r\n\r\n  watch: \r\n  {\r\n    taskId: 'fetchTaskData',\r\n  },\r\n  \r\n  created() \r\n  {\r\n    this.fetchTaskData();\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* Ajoutez des styles CSS pour le message de succès */\r\n.text-success\r\n{\r\n  margin-top: 10px;\r\n  color: green;\r\n}\r\n</style>\r\n"],"mappings":"AAqCA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eACA;EACEC,IAAIA,CAAA,EACJ;IACE,OAAO;MACLC,QAAQ,EACR;QACEC,KAAK,EAAE,EAAE;QACTC,WAAW,EAAE,EAAE;QACfC,QAAQ,EAAE,EAAE;QACZC,MAAM,EAAE;MACV,CAAC;MACDC,MAAM,EAAE,IAAI,CAACC,MAAM,CAACC,MAAM,CAACF,MAAM;MACjCG,OAAO,EAAE,KAAK;MAAE;MAChBC,cAAc,EAAE,EAAE,CAAE;IACtB,CAAC;EACH,CAAC;;EAEDC,OAAO,EACP;IACE,MAAMC,UAAUA,CAAA,EAChB;MACE,IAAI;QACF,IAAI,CAACH,OAAM,GAAI,IAAI,EAAE;QACrB,MAAMI,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;QAC3C,MAAMC,OAAM,GAAI;UAAEC,aAAa,EAAG,UAASJ,KAAM;QAAE,CAAC;QACpD,MAAMd,KAAK,CAACmB,GAAG,CAAE,yBAAwB,IAAI,CAACZ,MAAO,EAAC,EAAE,IAAI,CAACL,QAAQ,EAAE;UAAEe;QAAQ,CAAC,CAAC;QACnF;QACA,IAAI,CAACN,cAAa,GAAI,gCAAgC;MACxD,EAEA,OAAOS,KAAK,EACZ;QACEC,OAAO,CAACC,GAAG,CAACF,KAAK,CAAC;MACpB,UAGA;QACE,IAAI,CAACV,OAAM,GAAI,KAAK,EAAE;MACxB;IACF,CAAC;;IAED,MAAMa,aAAaA,CAAA,EACnB;MACE,IACA;QACE,MAAMT,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;QAC3C,MAAMC,OAAM,GAAI;UAAEC,aAAa,EAAG,UAASJ,KAAM;QAAE,CAAC;QACpD,MAAMU,QAAO,GAAI,MAAMxB,KAAK,CAACyB,GAAG,CAAE,cAAa,IAAI,CAAClB,MAAO,EAAC,EAAE;UAAEU;QAAQ,CAAC,CAAC;QAC1E;QACA,MAAMf,QAAO,GAAIsB,QAAQ,CAACvB,IAAI;QAC9BC,QAAQ,CAACG,QAAO,GAAI,IAAIqB,IAAI,CAACxB,QAAQ,CAACG,QAAQ,CAAC,CAACsB,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;QAC3E,IAAI,CAAC1B,QAAO,GAAIsB,QAAQ,CAACvB,IAAI;MAC/B,EAEA,OAAOmB,KAAK,EACZ;QACEC,OAAO,CAACC,GAAG,CAACF,KAAK,CAACS,OAAO,CAAC;MAC5B;IACF;EACF,CAAC;EAEDC,KAAK,EACL;IACEvB,MAAM,EAAE;EACV,CAAC;EAEDwB,OAAOA,CAAA,EACP;IACE,IAAI,CAACR,aAAa,CAAC,CAAC;EACtB;AACF,CAAC"},"metadata":{},"sourceType":"module","externalDependencies":[]}