{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nimport TaskForm from '../components/TaskForm.vue';\nimport TaskList from '../components/TaskList.vue';\nexport default {\n  name: \"UserPage\",\n  components: {\n    TaskForm,\n    TaskList\n  },\n  data() {\n    return {\n      tasks: [],\n      showTaskForm: false,\n      // Indicateur pour afficher/masquer le formulaire d'ajout de tâche\n      showTaskList: true,\n      // Indicateur pour afficher/masquer la liste des tâches par défaut\n      loadingTasks: false // Indicateur pour activer/désactiver l'animation de chargement\n    };\n  },\n\n  created() {\n    // Chargez les tâches de l'utilisateur lors de l'affichage de la page d'accueil\n    this.fetchTasks();\n  },\n  methods: {\n    // Fonction pour charger les tâches de l'utilisateur\n    async fetchTasks() {\n      try {\n        this.loadingTasks = true; // Activez l'animation de chargement\n        const token = localStorage.getItem('token');\n        const headers = {\n          Authorization: `Bearer ${token}`\n        };\n        const response = await axios.get('/api/tasks/', {\n          headers\n        });\n        this.tasks = response.data;\n      } catch (error) {\n        console.error(error);\n      } finally {\n        this.loadingTasks = false; // Désactivez l'animation de chargement une fois les tâches chargées\n      }\n    },\n\n    // Fonction pour se déconnecter\n    async logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    },\n    // Fonction pour basculer l'affichage du formulaire d'ajout de tâche\n    toggleTaskForm() {\n      this.showTaskForm = !this.showTaskForm;\n      // Si la liste des tâches est visible, la masquer\n      if (this.showTaskList) {\n        this.showTaskList = false;\n      }\n    },\n    // Fonction pour basculer l'affichage de la liste des tâches\n    toggleTaskList() {\n      this.showTaskList = !this.showTaskList;\n      // Si le formulaire d'ajout de tâche est visible, le masquer\n      if (this.showTaskForm) {\n        this.showTaskForm = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","TaskForm","TaskList","name","components","data","tasks","showTaskForm","showTaskList","loadingTasks","created","fetchTasks","methods","token","localStorage","getItem","headers","Authorization","response","get","error","console","logout","removeItem","$router","push","toggleTaskForm","toggleTaskList"],"sources":["C:\\Users\\melek\\Downloads\\projjett\\TaskManager-FullStackWebApp-GestionnairedeTaches-ApplicationFullStack\\frontend\\src\\views\\UserPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"container\">\r\n    <h2>Bienvenue sur votre gestionnaire de tâches</h2>\r\n\r\n    <!-- Bouton pour afficher le formulaire d'ajout de tâche -->\r\n    <button @click=\"toggleTaskForm\" class=\"btn btn-success\">Ajouter une nouvelle tâche</button>\r\n\r\n    <!-- Formulaire d'ajout de tâche (affiché lorsque showTaskForm est vrai) -->\r\n    <task-form v-if=\"showTaskForm\" @task-added=\"fetchTasks\" />\r\n\r\n    <!-- Bouton pour afficher la liste des tâches -->\r\n    <button @click=\"toggleTaskList\" class=\"btn btn-primary\">Voir la liste de vos tâches</button>\r\n\r\n    <!-- Liste des tâches (affichée lorsque showTaskList est vrai) -->\r\n    <div v-if=\"showTaskList\">\r\n      <task-list :tasks=\"tasks\" @task-deleted=\"fetchTasks\" />\r\n      <div v-if=\"loadingTasks\" class=\"loading-animation\">Chargement en cours...</div>\r\n    </div>\r\n\r\n    <!-- Bouton de déconnexion -->\r\n    <button @click=\"logout\" class=\"btn btn-danger\">Se déconnecter</button>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios';\r\nimport TaskForm from '../components/TaskForm.vue';\r\nimport TaskList from '../components/TaskList.vue';\r\n\r\nexport default \r\n{\r\n  name: \"UserPage\",\r\n  components: \r\n  {\r\n    TaskForm,\r\n    TaskList,\r\n  },\r\n\r\n  data() \r\n  {\r\n    return {\r\n      tasks: [],\r\n      showTaskForm: false, // Indicateur pour afficher/masquer le formulaire d'ajout de tâche\r\n      showTaskList: true, // Indicateur pour afficher/masquer la liste des tâches par défaut\r\n      loadingTasks: false, // Indicateur pour activer/désactiver l'animation de chargement\r\n    };\r\n  },\r\n\r\n  created() \r\n  {\r\n    // Chargez les tâches de l'utilisateur lors de l'affichage de la page d'accueil\r\n    this.fetchTasks();\r\n  },\r\n\r\n  methods: \r\n  {\r\n    // Fonction pour charger les tâches de l'utilisateur\r\n    async fetchTasks() \r\n    {\r\n      try \r\n      {\r\n        this.loadingTasks = true; // Activez l'animation de chargement\r\n        const token = localStorage.getItem('token');\r\n        const headers = { Authorization: `Bearer ${token}` };\r\n        const response = await axios.get('/api/tasks/', { headers });\r\n        this.tasks = response.data;\r\n      } \r\n\r\n      catch (error) \r\n      {\r\n        console.error(error);\r\n      } \r\n      \r\n      finally \r\n      {\r\n        this.loadingTasks = false; // Désactivez l'animation de chargement une fois les tâches chargées\r\n      }\r\n    },\r\n\r\n    // Fonction pour se déconnecter\r\n    async logout() \r\n    {\r\n      localStorage.removeItem('token');\r\n      this.$router.push('/login');\r\n    },\r\n\r\n    // Fonction pour basculer l'affichage du formulaire d'ajout de tâche\r\n    toggleTaskForm() \r\n    {\r\n      this.showTaskForm = !this.showTaskForm;\r\n      // Si la liste des tâches est visible, la masquer\r\n      if (this.showTaskList) \r\n      {\r\n        this.showTaskList = false;\r\n      }\r\n    },\r\n\r\n    // Fonction pour basculer l'affichage de la liste des tâches\r\n    toggleTaskList() \r\n    {\r\n      this.showTaskList = !this.showTaskList;\r\n      // Si le formulaire d'ajout de tâche est visible, le masquer\r\n      if (this.showTaskForm) \r\n      {\r\n        this.showTaskForm = false;\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.container \r\n{\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\nh2 \r\n{\r\n  margin-top: 20px;\r\n}\r\n\r\n.btn \r\n{\r\n  margin-top: 20px;\r\n  width: 100%;\r\n}\r\n</style>\r\n"],"mappings":";AAyBA,OAAOA,KAAI,MAAO,OAAO;AACzB,OAAOC,QAAO,MAAO,4BAA4B;AACjD,OAAOC,QAAO,MAAO,4BAA4B;AAEjD,eACA;EACEC,IAAI,EAAE,UAAU;EAChBC,UAAU,EACV;IACEH,QAAQ;IACRC;EACF,CAAC;EAEDG,IAAIA,CAAA,EACJ;IACE,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,YAAY,EAAE,KAAK;MAAE;MACrBC,YAAY,EAAE,IAAI;MAAE;MACpBC,YAAY,EAAE,KAAK,CAAE;IACvB,CAAC;EACH,CAAC;;EAEDC,OAAOA,CAAA,EACP;IACE;IACA,IAAI,CAACC,UAAU,CAAC,CAAC;EACnB,CAAC;EAEDC,OAAO,EACP;IACE;IACA,MAAMD,UAAUA,CAAA,EAChB;MACE,IACA;QACE,IAAI,CAACF,YAAW,GAAI,IAAI,EAAE;QAC1B,MAAMI,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;QAC3C,MAAMC,OAAM,GAAI;UAAEC,aAAa,EAAG,UAASJ,KAAM;QAAE,CAAC;QACpD,MAAMK,QAAO,GAAI,MAAMlB,KAAK,CAACmB,GAAG,CAAC,aAAa,EAAE;UAAEH;QAAQ,CAAC,CAAC;QAC5D,IAAI,CAACV,KAAI,GAAIY,QAAQ,CAACb,IAAI;MAC5B,EAEA,OAAOe,KAAK,EACZ;QACEC,OAAO,CAACD,KAAK,CAACA,KAAK,CAAC;MACtB,UAGA;QACE,IAAI,CAACX,YAAW,GAAI,KAAK,EAAE;MAC7B;IACF,CAAC;;IAED;IACA,MAAMa,MAAMA,CAAA,EACZ;MACER,YAAY,CAACS,UAAU,CAAC,OAAO,CAAC;MAChC,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;IAC7B,CAAC;IAED;IACAC,cAAcA,CAAA,EACd;MACE,IAAI,CAACnB,YAAW,GAAI,CAAC,IAAI,CAACA,YAAY;MACtC;MACA,IAAI,IAAI,CAACC,YAAY,EACrB;QACE,IAAI,CAACA,YAAW,GAAI,KAAK;MAC3B;IACF,CAAC;IAED;IACAmB,cAAcA,CAAA,EACd;MACE,IAAI,CAACnB,YAAW,GAAI,CAAC,IAAI,CAACA,YAAY;MACtC;MACA,IAAI,IAAI,CAACD,YAAY,EACrB;QACE,IAAI,CAACA,YAAW,GAAI,KAAK;MAC3B;IACF;EACF;AACF,CAAC"},"metadata":{},"sourceType":"module","externalDependencies":[]}