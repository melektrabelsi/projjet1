{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'RegisterPage',\n  data() {\n    return {\n      email: '',\n      password: '',\n      confirmPassword: '',\n      error: ''\n    };\n  },\n  methods: {\n    async registerUser() {\n      try {\n        // Vérifiez si le mot de passe et la confirmation correspondent\n        if (this.password !== this.confirmPassword) {\n          this.error = 'Les mots de passe ne correspondent pas.';\n          return;\n        }\n\n        // Vérifiez la longueur du mot de passe\n        if (this.password.length < 5) {\n          this.error = 'Le mot de passe doit comporter au moins 5 caractères.';\n          return;\n        }\n\n        // Vérifiez s'il y a au moins un caractère spécial dans le mot de passe\n        const specialCharacterRegex = /[!@#$%^&*()_+\\-=[\\]{};':\"|,.<>/?]+/;\n        if (!specialCharacterRegex.test(this.password)) {\n          this.error = 'Le mot de passe doit contenir au moins un caractère spécial.';\n          return;\n        }\n        const response = await axios.post('/api/auth/register', {\n          email: this.email,\n          password: this.password\n        });\n        localStorage.setItem('token', response.data.token);\n        this.$router.push('/login');\n      } catch (error) {\n        this.error = 'Erreur lors de l\\'inscription.';\n        console.log(error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","email","password","confirmPassword","error","methods","registerUser","length","specialCharacterRegex","test","response","post","localStorage","setItem","token","$router","push","console","log"],"sources":["C:\\Users\\melek\\Downloads\\projjett\\TaskManager-FullStackWebApp-GestionnairedeTaches-ApplicationFullStack\\frontend\\src\\views\\Register.vue"],"sourcesContent":["<template>\r\n  <div class=\"container\">\r\n    <h2>Inscription</h2>\r\n    <form @submit.prevent=\"registerUser\">\r\n      <div class=\"form-group\">\r\n        <label for=\"email\">Email :</label>\r\n        <input type=\"email\" id=\"email\" v-model=\"email\" class=\"form-control\" required>\r\n      </div>\r\n      <div class=\"form-group\">\r\n        <label for=\"password\">Mot de passe :</label>\r\n        <input type=\"password\" id=\"password\" v-model=\"password\" class=\"form-control\" required>\r\n      </div>\r\n      <div class=\"form-group\">\r\n        <label for=\"confirmPassword\">Confirmez le mot de passe :</label>\r\n        <input type=\"password\" id=\"confirmPassword\" v-model=\"confirmPassword\" class=\"form-control\" required>\r\n      </div>\r\n      <button type=\"submit\" class=\"btn btn-primary\">S'inscrire</button>\r\n    </form>\r\n    <p v-if=\"error !== ''\" class=\"text-danger\">{{ error }}</p>\r\n    <p>Déjà inscrit? <router-link to=\"/login\">Connectez-vous</router-link></p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios';\r\n\r\nexport default {\r\n  name: 'RegisterPage',\r\n  data() {\r\n    return {\r\n      email: '',\r\n      password: '',\r\n      confirmPassword: '',\r\n      error: '',\r\n    };\r\n  },\r\n  methods: {\r\n    async registerUser() {\r\n      try {\r\n        // Vérifiez si le mot de passe et la confirmation correspondent\r\n        if (this.password !== this.confirmPassword) {\r\n          this.error = 'Les mots de passe ne correspondent pas.';\r\n          return;\r\n        }\r\n\r\n        // Vérifiez la longueur du mot de passe\r\n        if (this.password.length < 5) {\r\n          this.error = 'Le mot de passe doit comporter au moins 5 caractères.';\r\n          return;\r\n        }\r\n\r\n        // Vérifiez s'il y a au moins un caractère spécial dans le mot de passe\r\n        const specialCharacterRegex = /[!@#$%^&*()_+\\-=[\\]{};':\"|,.<>/?]+/;\r\n        if (!specialCharacterRegex.test(this.password)) {\r\n          this.error = 'Le mot de passe doit contenir au moins un caractère spécial.';\r\n          return;\r\n        }\r\n\r\n        const response = await axios.post('/api/auth/register', {\r\n          email: this.email,\r\n          password: this.password,\r\n        });\r\n\r\n        localStorage.setItem('token', response.data.token);\r\n        this.$router.push('/login');\r\n      } catch (error) {\r\n        this.error = 'Erreur lors de l\\'inscription.';\r\n        console.log(error);\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.container {\r\n  max-width: 400px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n.form-group {\r\n  margin-bottom: 15px;\r\n}\r\n.btn-primary {\r\n  width: 100%;\r\n}\r\n</style>\r\n"],"mappings":";AAwBA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,eAAe,EAAE,EAAE;MACnBC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF;QACA,IAAI,IAAI,CAACJ,QAAO,KAAM,IAAI,CAACC,eAAe,EAAE;UAC1C,IAAI,CAACC,KAAI,GAAI,yCAAyC;UACtD;QACF;;QAEA;QACA,IAAI,IAAI,CAACF,QAAQ,CAACK,MAAK,GAAI,CAAC,EAAE;UAC5B,IAAI,CAACH,KAAI,GAAI,uDAAuD;UACpE;QACF;;QAEA;QACA,MAAMI,qBAAoB,GAAI,oCAAoC;QAClE,IAAI,CAACA,qBAAqB,CAACC,IAAI,CAAC,IAAI,CAACP,QAAQ,CAAC,EAAE;UAC9C,IAAI,CAACE,KAAI,GAAI,8DAA8D;UAC3E;QACF;QAEA,MAAMM,QAAO,GAAI,MAAMZ,KAAK,CAACa,IAAI,CAAC,oBAAoB,EAAE;UACtDV,KAAK,EAAE,IAAI,CAACA,KAAK;UACjBC,QAAQ,EAAE,IAAI,CAACA;QACjB,CAAC,CAAC;QAEFU,YAAY,CAACC,OAAO,CAAC,OAAO,EAAEH,QAAQ,CAACV,IAAI,CAACc,KAAK,CAAC;QAClD,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;MAC7B,EAAE,OAAOZ,KAAK,EAAE;QACd,IAAI,CAACA,KAAI,GAAI,gCAAgC;QAC7Ca,OAAO,CAACC,GAAG,CAACd,KAAK,CAAC;MACpB;IACF;EACF;AACF,CAAC"},"metadata":{},"sourceType":"module","externalDependencies":[]}