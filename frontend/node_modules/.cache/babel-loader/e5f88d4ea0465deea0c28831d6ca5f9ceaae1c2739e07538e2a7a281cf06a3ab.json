{"ast":null,"code":"import axios from 'axios';\nexport default {\n  data() {\n    return {\n      title: '',\n      description: '',\n      deadline: '',\n      status: 'Envisagé',\n      // Valeur par défaut du statut,\n      message: \"\"\n    };\n  },\n  methods: {\n    async addTask() {\n      try {\n        const token = localStorage.getItem('token'); // Assurez-vous de stocker le token correctement\n        const headers = {\n          Authorization: `Bearer ${token}`\n        };\n        const data = {\n          title: this.title,\n          description: this.description,\n          deadline: this.deadline,\n          status: this.status // Ajout du statut\n        };\n        //console.log(data)\n        await axios.post('/api/tasks/newtask', {\n          data: data\n        }, {\n          headers: {\n            ...headers,\n            'Content-Type': 'application/json'\n          }\n        });\n        this.$emit('task-added'); // Émet un événement pour informer le parent de l'ajout de la tâche\n        this.title = '';\n        this.description = '';\n        this.deadline = '';\n        this.message = \"Tâche ajoutée avec succès\";\n        setTimeout(() => {\n          this.message = \"\";\n        }, 5000);\n      } catch (error) {\n        console.log(error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","data","title","description","deadline","status","message","methods","addTask","token","localStorage","getItem","headers","Authorization","post","$emit","setTimeout","error","console","log"],"sources":["C:\\Users\\melek\\Downloads\\projjett\\TaskManager-FullStackWebApp-GestionnairedeTaches-ApplicationFullStack\\frontend\\src\\components\\TaskForm.vue"],"sourcesContent":["<template>\r\n    <div>\r\n      <h3>Ajouter une nouvelle tâche</h3>\r\n      <form @submit.prevent=\"addTask\">\r\n        <div class=\"form-group\">\r\n          <label for=\"title\">Titre :</label>\r\n          <input type=\"text\" id=\"title\" v-model=\"title\" class=\"form-control\" required>\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label for=\"description\">Description :</label>\r\n          <textarea id=\"description\" v-model=\"description\" class=\"form-control\" required></textarea>\r\n        </div>\r\n        <div class=\"form-group\">\r\n          <label for=\"deadline\">Date limite :</label>\r\n          <input type=\"date\" id=\"deadline\" v-model=\"deadline\" class=\"form-control\" required>\r\n        </div>\r\n        <div class=\"form-group\">\r\n            <label for=\"status\">Statut :</label>\r\n            <select id=\"status\" v-model=\"status\" class=\"form-control\" required>\r\n              <option selected value=\"Envisagé\">Envisagé</option>\r\n              <option value=\"En cours\">En cours</option>\r\n              <option value=\"Terminée\">Terminée</option>\r\n              <option value=\"En attente\">En attente</option>\r\n            </select>\r\n        </div>\r\n        <button type=\"submit\" class=\"btn btn-success\">Ajouter</button>\r\n      </form>\r\n      <p class=\"text-success\"> {{ message }}   </p>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import axios from 'axios';\r\n  \r\n  export default {\r\n    data() {\r\n      return {\r\n        title: '',\r\n        description: '',\r\n        deadline: '',\r\n        status: 'Envisagé', // Valeur par défaut du statut,\r\n        message: \"\"\r\n      };\r\n    },\r\n    methods: {\r\n        async addTask() \r\n        {\r\n            try {\r\n                const token = localStorage.getItem('token'); // Assurez-vous de stocker le token correctement\r\n                const headers = { Authorization: `Bearer ${token}` };\r\n                const data = \r\n                {\r\n                title: this.title,\r\n                description: this.description,\r\n                deadline: this.deadline,\r\n                status: this.status, // Ajout du statut\r\n                };\r\n                //console.log(data)\r\n                await axios.post('/api/tasks/newtask',  {data: data} ,  { headers: {...headers,'Content-Type': 'application/json', },});\r\n                this.$emit('task-added'); // Émet un événement pour informer le parent de l'ajout de la tâche\r\n                this.title = '';\r\n                this.description = '';\r\n                this.deadline = '';\r\n                \r\n                this.message = \"Tâche ajoutée avec succès\"\r\n\r\n                setTimeout(()=>\r\n                {\r\n                  this.message = \"\"\r\n                }, 5000)\r\n            } \r\n            catch (error) \r\n            {\r\n                console.log(error);\r\n            }\r\n        },\r\n    },\r\n  };\r\n  </script>\r\n  \r\n  <style scoped>\r\n  /* Utilisez ici vos styles CSS pour personnaliser l'apparence du formulaire de tâche */\r\n  </style>\r\n  "],"mappings":"AAgCE,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,WAAW,EAAE,EAAE;MACfC,QAAQ,EAAE,EAAE;MACZC,MAAM,EAAE,UAAU;MAAE;MACpBC,OAAO,EAAE;IACX,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,OAAOA,CAAA,EACb;MACI,IAAI;QACA,MAAMC,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,EAAE;QAC7C,MAAMC,OAAM,GAAI;UAAEC,aAAa,EAAG,UAASJ,KAAM;QAAE,CAAC;QACpD,MAAMR,IAAG,GACT;UACAC,KAAK,EAAE,IAAI,CAACA,KAAK;UACjBC,WAAW,EAAE,IAAI,CAACA,WAAW;UAC7BC,QAAQ,EAAE,IAAI,CAACA,QAAQ;UACvBC,MAAM,EAAE,IAAI,CAACA,MAAM,CAAE;QACrB,CAAC;QACD;QACA,MAAML,KAAK,CAACc,IAAI,CAAC,oBAAoB,EAAG;UAACb,IAAI,EAAEA;QAAI,GAAK;UAAEW,OAAO,EAAE;YAAC,GAAGA,OAAO;YAAC,cAAc,EAAE;UAAoB;QAAE,CAAC,CAAC;QACvH,IAAI,CAACG,KAAK,CAAC,YAAY,CAAC,EAAE;QAC1B,IAAI,CAACb,KAAI,GAAI,EAAE;QACf,IAAI,CAACC,WAAU,GAAI,EAAE;QACrB,IAAI,CAACC,QAAO,GAAI,EAAE;QAElB,IAAI,CAACE,OAAM,GAAI,2BAA0B;QAEzCU,UAAU,CAAC,MACX;UACE,IAAI,CAACV,OAAM,GAAI,EAAC;QAClB,CAAC,EAAE,IAAI;MACX,EACA,OAAOW,KAAK,EACZ;QACIC,OAAO,CAACC,GAAG,CAACF,KAAK,CAAC;MACtB;IACJ;EACJ;AACF,CAAC"},"metadata":{},"sourceType":"module","exter